{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "hono",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": ".",
  "crons": [
    {
      "path": "/cron/sweep",
      "schedule": "0 * * * *"
    },
    {
      "path": "/cron/reconcile",
      "schedule": "0 6 * * *"
    }
  ]
}

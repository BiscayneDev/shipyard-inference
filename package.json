{
  "name": "shipyard-inference",
  "version": "0.15.0",
  "description": "The always-available inference layer for the Shipyard stack: streaming, cost-aware routing, x402-on-Solana payments, and a drop-in OpenAI-compatible gateway over Anthropic, OpenAI, UsePod, and Nous/Hermes.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./gateway": {
      "import": "./dist/gateway/index.js",
      "types": "./dist/gateway/index.d.ts"
    },
    "./operator": {
      "import": "./dist/operator/index.js",
      "types": "./dist/operator/index.d.ts"
    }
  },
  "bin": {
    "shipyard-inference": "./dist/connect/bin.js",
    "shipyard-gateway": "./dist/gateway/bin.js",
    "shipyard-operator": "./dist/operator/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "copy-assets": "rm -rf dist/operator/public && cp -R src/operator/public dist/operator/public",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx test/*.test.ts",
    "clean": "rm -rf dist",
    "build:web": "node scripts/build-web.mjs",
    "vercel-build": "npm run build && npm run build:web",
    "prepublishOnly": "npm run clean && npm run build",
    "build:portal-wallet": "esbuild examples/chat-portal/public/src/wallet.js --bundle --format=iife --target=es2020 --minify --outfile=examples/chat-portal/public/wallet-bundle.js"
  },
  "keywords": [
    "shipyard",
    "agent",
    "llm",
    "inference",
    "anthropic",
    "openai",
    "usepod",
    "proxy",
    "router",
    "solana",
    "x402",
    "payments"
  ],
  "author": "Halsey Huth <halsey.huth@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BiscayneDev/shipyard-inference.git"
  },
  "bugs": {
    "url": "https://github.com/BiscayneDev/shipyard-inference/issues"
  },
  "homepage": "https://github.com/BiscayneDev/shipyard-inference#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "bs58": "^5.0.0",
    "openai": "^6.32.0"
  },
  "peerDependencies": {
    "@coral-xyz/anchor": "^0.30 || ^0.31 || ^0.32",
    "@hono/node-server": "^1 || ^2",
    "@paybox-sh/sdk": "^0.1.0",
    "@solana/spl-token": "^0.4.0",
    "@solana/web3.js": "^1.95.0",
    "hono": "^4"
  },
  "peerDependenciesMeta": {
    "@solana/web3.js": {
      "optional": true
    },
    "@solana/spl-token": {
      "optional": true
    },
    "@paybox-sh/sdk": {
      "optional": true
    },
    "hono": {
      "optional": true
    },
    "@hono/node-server": {
      "optional": true
    },
    "@coral-xyz/anchor": {
      "optional": true
    }
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@hono/node-server": "^2.0.4",
    "@paybox-sh/sdk": "^0.1.0",
    "@solana/spl-token": "^0.4.0",
    "@solana/web3.js": "^1.95.0",
    "@types/node": "^20",
    "@vercel/functions": "^3.7.0",
    "esbuild": "^0.28.0",
    "hono": "^4.12.25",
    "tsx": "^4.19.0",
    "typescript": "^5"
  }
}

{
  "name": "shipyard-inference",
  "version": "0.3.0",
  "description": "The always-available inference layer for the Shipyard stack. Cost-aware routing and x402-on-Solana payments over Anthropic, OpenAI, and UsePod behind one LLMProvider interface.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx test/*.test.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "shipyard",
    "agent",
    "llm",
    "inference",
    "anthropic",
    "openai",
    "usepod",
    "proxy",
    "router",
    "solana",
    "x402",
    "payments"
  ],
  "author": "Halsey Huth <halsey.huth@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BiscayneDev/shipyard-inference.git"
  },
  "bugs": {
    "url": "https://github.com/BiscayneDev/shipyard-inference/issues"
  },
  "homepage": "https://github.com/BiscayneDev/shipyard-inference#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "openai": "^6.32.0"
  },
  "peerDependencies": {
    "@solana/web3.js": "^1.95.0",
    "@solana/spl-token": "^0.4.0",
    "@paybox-sh/sdk": "^0.1.0"
  },
  "peerDependenciesMeta": {
    "@solana/web3.js": { "optional": true },
    "@solana/spl-token": { "optional": true },
    "@paybox-sh/sdk": { "optional": true }
  },
  "devDependencies": {
    "@paybox-sh/sdk": "^0.1.0",
    "@solana/spl-token": "^0.4.0",
    "@solana/web3.js": "^1.95.0",
    "@types/node": "^20",
    "tsx": "^4.19.0",
    "typescript": "^5"
  }
}
